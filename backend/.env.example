# =============================================================================
# Federated Healthcare AI — Backend environment variables
# =============================================================================
# Copy to backend/.env (local uvicorn) or use project-root .env with docker-compose.
# Never commit real secrets. Docker/CI variables override .env file values.

# --- Runtime ---
ENVIRONMENT=development
DEBUG=true
APP_TITLE=Federated Healthcare AI API
APP_VERSION=1.0.0

# --- PostgreSQL (required for analytics / audit logs) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/fedhealth_ai

# --- JWT (required in production) ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

# --- CORS (comma-separated origins; use * only for local dev) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Demo login passwords (override before production deployment) ---
AUTH_ADMIN_PASSWORD=admin123
AUTH_DOCTOR_PASSWORD=doctor123
AUTH_ANALYST_PASSWORD=analyst123

# --- ML artifacts (paths relative to backend/ unless absolute) ---
MODEL_PATH=models/global_federated_model.pth
SCALER_PATH=scalers/scaler.joblib
FEATURE_NAMES_PATH=scalers/feature_names.joblib
FEATURE_MEDIANS_PATH=scalers/feature_medians.joblib
DEFAULT_MODEL_VERSION=FTTransformer_v24_unified
