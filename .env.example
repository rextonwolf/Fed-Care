# =============================================================================
# Federated Healthcare AI Platform — Environment template
# =============================================================================
# Copy to .env at the project root for docker-compose and local development.
# backend/.env is also loaded when running the API from backend/api.

# --- Frontend (Next.js — exposed to the browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend / FastAPI ---
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/fedhealth_ai

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTH_ADMIN_PASSWORD=admin123
AUTH_DOCTOR_PASSWORD=doctor123
AUTH_ANALYST_PASSWORD=analyst123

MODEL_PATH=../models/global_federated_model.pth
SCALER_PATH=../scalers/scaler.joblib
DEFAULT_MODEL_VERSION=FTTransformer_v1
